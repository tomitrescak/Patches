generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatchDay {
  id           String   @id @default(cuid())
  dateKey      String   @unique
  patchChanged Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OptuneSession {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([startAt])
  @@index([endAt])
}

enum DailyActionType {
  EXERCISE
  MEDICINE
}

model DailyAction {
  id         String          @id @default(cuid())
  type       DailyActionType
  occurredAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([occurredAt])
  @@index([type])
}
