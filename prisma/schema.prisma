generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatchDay {
  id           String   @id @default(cuid())
  dateKey      String   @unique
  patchChanged Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OptuneSession {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([startAt])
  @@index([endAt])
}
